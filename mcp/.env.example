# Socialbrand Visual Generator - Environment Configuration
# Copy file ini ke .env dan masukkan API key kamu

# fal.ai API Key
# Dapatkan gratis di: https://fal.ai
# Free tier: generous limits untuk development & testing
FAL_API_KEY=your_fal_api_key_here

# Optional: Custom fal.ai endpoint (default: https://api.fal.ai)
# FAL_API_ENDPOINT=https://api.fal.ai

# Optional: Request timeout dalam detik (default: 120)
# FAL_REQUEST_TIMEOUT=120

# Optional: Enable debug logging
# DEBUG=false
